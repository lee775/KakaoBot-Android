<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <!-- 상단 툴바 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#16213e"
        android:padding="8dp"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="< 뒤로"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.TextButton" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="스크립트 편집기"
            android:textColor="#e94560"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="저장"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.TonalButton" />
    </LinearLayout>

    <!-- 상태바 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0d1b36"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvFileInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="bot_script.js"
            android:textColor="#a0a0a0"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvCharCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 chars"
            android:textColor="#a0a0a0"
            android:textSize="11sp"
            android:paddingStart="8dp" />
    </LinearLayout>

    <!-- 버튼 행: 파일교체 / 기본값복원 / 저장+리로드 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnImportFile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="파일 교체"
            android:textSize="11sp"
            android:layout_marginEnd="2dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResetDefault"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="기본값 복원"
            android:textSize="11sp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveAndReload"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="저장+리로드"
            android:textSize="11sp"
            android:layout_marginStart="2dp"
            style="@style/Widget.Material3.Button.TonalButton" />
    </LinearLayout>

    <!-- 코드 편집 영역 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0f3460"
        android:fillViewport="true">

        <EditText
            android:id="@+id/etCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:textColor="#53ff53"
            android:textColorHint="#2a6a2a"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:gravity="top|start"
            android:padding="8dp"
            android:inputType="textMultiLine|textNoSuggestions"
            android:scrollHorizontally="true"
            android:hint="여기에 JavaScript 코드를 입력하세요..." />
    </ScrollView>

</LinearLayout>
